#********************************
# Basic-256 program with a GUI:
#            Mandelbrot-256
#
# 31/05/2013: 
# Whoopsie! Apparently the program on the (long gone) website had been broken for quite some time....
# I have now updated it to work with the new color mechanism implemented as of 0.9.9.28
#
#21/10/2024:
#...and slightly more than a decade later, I have updated it to 2.0.0.11!!
# Made it quite a bit larger (beefy PC is required) and improved the Full Julia set creation
#Colorhandling internally is a mess, but still, nice results can be had
#********************************
#  Setup
#********************************
#basic initialisation
graphsize 1200,625
#graphvisible(1)
editvisible(0)
outputvisible(0)
fastgraphics
swabout=0
swreturn=0
sw_cb=0
gosub splash
graphsize 1200,625
clg
#Variable Initialization
sw_print=0
swzm=0
swzoom=0
swcpy=0
sw_bigger=0
sw_FullJulia=0
sw_custseg=0
sw_trail=0
rood=0:blauw=0:groen=0
real=0:oldreal=0
imag=0:oldimag=0
tel=0
oldxdot=-4
oldydot=-4
dim colorbandnew(3,256) fill 0
# slider creation
# draw the slider
spritedim 4
color black
circle 150,140,7
color darkgrey
circle 150,140,6
color rgb(200,200,200)
circle 150,140,5
color white
circle 152,138,2
spriteslice 0,143,133,15,15
spriteslice 1,143,133,15,15
spriteslice 2,143,133,15,15
spriteslice 3,143,133,15,15
#initialize color bars
gosub CreateColor
# Set up Main Drawing Area
color grey
rect 0,0,1199,599
draw_locx = 10:draw_locy = 10
draw_width = 566:draw_height = 578
draw_offsetx = 0: draw_offsety=0
draw_insetx = 0.02: draw_insety=0.02
draw_elements_x=1:draw_elements_y=1
draw_color=2
gosub drawing
start_drawx=10
width_drawx=568
start_drawy=10
height_drawy=580
# set up Vertical separator
color darkgrey
rect 596,8,2,578
color rgb(200,200,200)
rect 600,8,2,578
#set up tabs
tab_locx=620:tab_locy=10
tab_width=560:tab_height=30
dim tab1$(5)
tab1$={"Mandel","Julia","Orbits","Zoom","Colors"}
tab_elements=5
tab_active=1
gosub drawtabs
# Initial screen draw with Mandelbrot
sw_sel$="Mand"
mand_radio_active=1
color_radio_active=1
#init of the main complex map settings
gosub InitComplexMap
#paint the Mandel-tab
gosub Screen_Mandel
#force initial creation of the Mandelbrot set
gosub MandelDraw
#after initial draw, increase iterations to 100
k=100
#*******************************************
# Main Loop:
#      actions are triggered by mouse events
#*******************************************
loop:
# is the mouse active on the Tab-area?
if mousey > tab_locy and mousey < tab_locy+tab_height then
   while mouseb=1
      if mousex > tab_locx and mousex < tab_locx+tab_width_single then
         gosub Screen_Mandel
         sw_sel$="Mand"
      else
         if mousex > tab_locx+tab_width_single and mousex < tab_locx+tab_width_single *2 then
            gosub Screen_Julia
            sw_sel$="Julia"
         else
            if mousex > tab_locx+tab_width_single*2 and mousex < tab_locx+tab_width_single *3 then
               gosub Screen_Orbits
               sw_sel$="Orbits"
            else
               if mousex > tab_locx+tab_width_single*3 and mousex < tab_locx+tab_width_single *4 then
                  sw_sel$="Zoom"
                  gosub Screen_Zoom
               else
                  if mousex > tab_locx+tab_width_single*4 and mousex < tab_locx+tab_width_single *5 then
                     sw_sel$="Colors"
                     gosub Screen_Colour
                  end if
               end if
            end if
         end if
      end if
      clickclear
      pause 0.01
   end while
end if
#*****************************
#  Activity on Mandel Tab !!
#*****************************
if sw_sel$="Mand" then
   # check for Radio button activity
   if mousex > radio_locx-5 and mousex < radio_locx+5 then
      while mouseb = 1
         for i = 0 to radio_elements-1
            if mousey > radio_locy_top-5 + i*radio_spacing-5 and mousey < radio_locy_top + i*radio_spacing+5 then
               color white
               circle radio_locx+1, radio_locy_top+1*(radio_spacing*(mand_radio_active-1)),2
               color black
               circle radio_locx+1, radio_locy_top+1*(radio_spacing*i),2
               mand_radio_active=i+1
               mand_algo=i+1
               refresh
            end if
         next i
      end while
   else
      # Check if the Calculate button has been pressed
      if mousex > b_update_locx and mousex < b_update_locx + b_update_width then
         while mouseb=1
            if mousey > b_update_locy and mousey < b_update_locy + b_update_height then
               # Press Calculate button
               b_text$= "Calculate":b_textsize=10
				b_offsetx=10:b_offsety=7
               b_pressed=1
			   b_locx=b_update_locx:b_locy=b_update_locy
			   b_height=b_update_height:b_width=b_update_width
               gosub drawbutton
               refresh
               pause 0.1
			   b_offsetx=12:b_offsety=3
               b_pressed=0
               gosub drawbutton
               refresh
               gosub MandelDraw
               Mandelbrot$=getslice (10,10,580,580)
            endif
         end while
      end if
      # Check if the Reset button has been pressed
      if mousex > b_reset_locx and mousex < b_reset_locx + b_reset_width then
         while mouseb=1
            if mousey > b_reset_locy and mousey < b_reset_locy + b_reset_height then
               # Press Reset button
               b_text$= "Reset":b_textsize=10
               b_offsetx=20:b_offsety=3
               b_pressed=1
               b_locx= b_reset_locx:b_locy=b_reset_locy
               b_height=b_reset_height:b_width=b_reset_width
               gosub drawbutton
               refresh
               pause 0.2
               b_pressed=0
               gosub drawbutton
               color_radio_active=1
               mand_radio_active=1
               gosub InitComplexMap
               gosub MandelDraw
            endif
         end while
      end if
   end if
end if
#*****************************
#  Activity on Julia Tab !!
#*****************************
if sw_sel$="Julia" then
   clickclear
   while mousex > 10 and mousex < 590 and mousey > 10 and mousey < 590
      real=(mousex-11)/580*(xmax-xmin)+xmin
      imag=(mousey-11)/580*(ymax-ymin)+ymin
      if (real  = oldreal) and (imag  = oldimag) then
         sw_FastJulia=1
         goto contin
      else
         sw_FastJulia=0
      end if
	  draw_locx = 750:draw_locy = 560
	  draw_width = 100:draw_height = 15
	  draw_offsetx = 100: draw_offsety=0
	  draw_insetx = 0.01: draw_insety=0.01
	  draw_elements_x=2:draw_elements_y=1
	  draw_color=1
	  gosub drawing
      color black
      font "Tahoma",10,10
      text 755,560,real
      text 955,560,imag
contin:
      refresh
      pause 0.01
      oldreal=real
      oldimag=imag
      gosub FastJulia
      if clickb=1 then
         gosub FullJulia
         sw_FullJulia=1
         clickclear
      endif
   end while
endif
#*****************************
#  Activity on Orbits Tab !!
#*****************************
if sw_sel$="Orbits" then
   while mousex > 10 and mousex < 590 and mousey > 10 and mousey < 590
      oldmousex=mousex:oldmousey=mousey
      real=(mousex-11)/580*(xmax-xmin)+xmin
      imag=(mousey-11)/580*(ymax-ymin)+ymin
      oldreal=real
      oldimag=imag
      draw_locx = 750:draw_locy = 560
      draw_width = 100:draw_height = 15
      draw_offsetx = 100: draw_offsety=0
      draw_insetx = 0.01: draw_insety=0.01
      draw_elements_x=2:draw_elements_y=1
      draw_color=1
      gosub drawing
      color black
      font "Tahoma",10,10
      text 755,560,real
      text 955,560,imag
      gosub OrbitView
      color black
      #      if not sw_trail then
      rect 680,120,430,430
      #      endif
      refresh
   end while
endif
#*****************************
#  Activity on Zoom Tab !!
#*****************************
if sw_sel$="Zoom" then
   if mousex > 670 and mousex < 955 and mousey > 100 and mousey < 385 then
      if swzoom=0 then
         gosub MandelZoom
      endif
   endif
   if mousex > slider_locx_top-8 and mousex < slider_locx_top+8 then
      while mouseb=1
         clickclear
         if mousey < slider_locy_top then
            kt=30
            spriteplace 0,slider_locx_top+5,90
         else
            if mousey > slider_locy_bot then
               kt=430
               spriteplace 0,slider_locx_top+5,400
            else
               kt=mousey-60
               spriteplace 0,slider_locx_top+5,mousey
            end if
         end if
         refresh
         pause 0.01
      end while
   endif
   if mousex > b_update_locx and mousex < b_update_locx+b_update_width then
      if mousey > b_update_locy and mousey < b_update_locy+b_update_height then
         swzoom=0
         while mouseb=1
            clickclear
            # Press Update button
            b_text$= "Update":b_textsize=12
            b_offsetx=20:b_offsety=3
            b_pressed=1
            b_locx= b_update_locx:b_locy=b_update_locy
            b_height=b_update_height:b_width=b_update_width
            gosub drawbutton
            refresh
            pause 0.2
            b_pressed=0
            gosub drawbutton
            gosub MandelDraw
            Mandelbrot$=getslice (10,10,580,580)
			for i = 10 to 580 step 2
			   for j = 10 to 578 step 2
			      colr=pixel(i,j)
			      color colr
			      plot 665+i/2,95+j/2
			   next j
			next i
			refresh
         end while
      endif
   endif
   if mousex > b_reset_locx and mousex < b_reset_locx+b_reset_width then
      if mousey > b_reset_locy and mousey < b_reset_locy+b_reset_height then
         swzoom=0
         while mouseb=1
            clickclear
            # Press Reset button
            b_text$= "Reset":b_textsize=12
            b_offsetx=20:b_offsety=3
            b_pressed=1
            b_locx= b_reset_locx:b_locy=b_reset_locy
            b_height=b_reset_height:b_width=b_reset_width
            gosub drawbutton
            refresh
            pause 0.2
            b_pressed=0
            gosub drawbutton
            color_radio_active=1
            mand_radio_active=1
            gosub InitComplexMap
            gosub MandelDraw
            gosub drawslider
            Mandelbrot$=getslice (10,10,580,580)
            for i = 10 to 580 step 2
              for j = 10 to 584 step 2
              colr=pixel(i,j)
              color colr
              plot 665+i/2,94+j/2
              next j
              refresh
            next i
            refresh
         end while
      endif
   endif
endif
#*****************************
#  Activity on Color Tab !!
#*****************************
if sw_sel$="Colors" then
   # check for Radio button activity
   if mousex > radio_locx-5 and mousex < radio_locx+5 then
      while mouseb = 1
         for i = 0 to color_radio_elements-1
            if mousey > color_radio_locy_top-5 + i*radio_spacing-5 and mousey < color_radio_locy_top + i*radio_spacing+5 then
               color white
               circle color_radio_locx+1, color_radio_locy_top+1*(radio_spacing*(color_radio_active-1)),2
               color black
               circle color_radio_locx+1, color_radio_locy_top+1*(radio_spacing*i),2
               color_radio_active=i+1
               refresh
            end if
         next i
      end while
   end if
   # check for Color customization button press
   if mousex > 865 and mousex < 895 then
      while mouseb = 1
         for i = 0 to 2
            if mousex > 865 and mousex < 895 and mousey > 350 and mousey < 365 + i*72 then
               UserCol=i
               b_pressed=0
               b_set_locy=350 +i*72:b_locy=b_set_locy
               b_set_height=15:b_height=b_set_height
               b_set_width=30:b_width=b_set_width
               b_pressed=1
               gosub drawsetbutton
               pause 0.1
               b_pressed=0
               gosub drawsetbutton
               refresh
               pause 0.1
               # initialize custom bar
               for j = 0 to 255 step 1
                  c=pixel(640+i,223+i*72)
                  colorbandnew[0,j]=(c & 0xff0000) \ 0x10000
                  colorbandnew[1,j]=(c & 0xff00) \ 0x100
                  colorbandnew[2,j]=(c & 0xff)
               next j
               rood=0:groen=0:blauw=0
               gosub Screen_Color_Chooser
               clickclear
            endif
         next i
      end while
   end if
end if
#*****************************
#  Activity on Color Customization !!
#*****************************
if sw_sel$="Colors_set" then
   # is the mouse on the red slider
   if mousey>475 and mousey <490 then
      while mouseb=1
         place=mousex
         if place < 926 then place = 926
         if place > 1182 then place=1182
         rood=place-926
         spriteplace 1,place,485
         pause 0.01
         gosub drwcolor
         refresh
      end while
      clickclear
   else
      # is the mouse on the green slider?
      if mousey>495 and mousey <510 then
         while mouseb=1
            place=mousex
            if place < 926 then place = 926
            if place > 1182 then place=1182
            groen=place-926
            spriteplace 2,place,505
            #           spriteshow 2
            pause 0.01
            gosub drwcolor
            refresh
         end while
         clickclear
      else
         # is the mouse on the blue slider?
         if mousey>515 and mousey <525 then
            while mouseb=1
               place=mousex
               if place < 926 then place = 926
               if place > 1182 then place=1182
               blauw=place-926
               spriteplace 3,place,525
               pause 0.01
               gosub drwcolor
               refresh
            end while
            clickclear
         endif
      endif
   endif
   # is the mouse on the colorbar?
   if mousex > 930 and mousex < 1182 then
      if mousey >345 and mousey < 355 then
         if sw_cb=0 then
            sw_cb=1
         endif
         place2=mousex-930
         if clickb=1 then
            # insert the selected color in the custom colorbar
            colorbandcustom[0,place2]=rood
            colorbandcustom[1,place2]=groen
            colorbandcustom[2,place2]=blauw
            gosub ColorbandCustom
            # color initial position            
		    b_text$= "":b_textsize=1
		    b_offsetx=0:b_offsety=-0
		    b_pressed=0
		    b_set_locx=930:b_locx=b_set_locx
		    b_set_locy=365:b_locy=b_set_locy
		    b_set_height=8:b_height=b_set_height
		    b_set_width=10:b_width=b_set_width
		    b_colr=colorbandnew[0,0]
		    b_colg=colorbandnew[1,0]
		    b_colb=colorbandnew[2,0]            
            gosub drawcolbutton
            # color final position
            b_text$= "":b_textsize=1
		    b_offsetx=0:b_offsety=-0
		    b_pressed=0
		    b_set_locx=1172:b_locx=b_set_locx
		    b_set_locy=365:b_locy=b_set_locy
		    b_set_height=10:b_height=b_set_height
		    b_set_width=10:b_width=b_set_width
		    b_colr=colorbandnew[0,0]
		    b_colg=colorbandnew[1,0]
		    b_colb=colorbandnew[2,0]    
		    gosub drawcolbutton
            refresh
            clickclear
            sw_cb=0
         end if
      end if
   end if
   # is the mouse on the slot 1 button?
   if mousex > 930 and mousex < 940 then
      while mouseb = 1
         if mousey > 365 and mousey < 375 then
            place2=0
            # insert the selected color in the custom colorbar
            colorbandcustom[0,place2]=rood
            colorbandcustom[1,place2]=groen
            colorbandcustom[2,place2]=blauw
            gosub ColorbandCustom
            # color initial position
            b_text$= "":b_textsize=1
            b_offsetx=0:b_offsety=-0
            b_pressed=0
            b_set_locx=930:b_locx=b_set_locx
            b_set_locy=365:b_locy=b_set_locy
            b_set_height=10:b_height=b_set_height
            b_set_width=10:b_width=b_set_width
		    b_colr=colorbandnew[0,0]
		    b_colg=colorbandnew[1,0]
		    b_colb=colorbandnew[2,0] 
            gosub drawcolbutton
            refresh
            #     end if
         end if
         clickclear
      end while
   end if
   # is the mouse on the slot 2 button?
   if mousex > 1172 and mousex < 1182 then
      while mouseb = 1
         if mousey > 365 and mousey < 375 then
            place2=255
            # insert the selected color in the custom colorbar
            colorbandcustom[0,place2]=rood
            colorbandcustom[1,place2]=groen
            colorbandcustom[2,place2]=blauw
            gosub ColorbandCustom
            # color final position
            b_text$= "":b_textsize=1
            b_offsetx=0:b_offsety=-0
            b_pressed=0
            b_set_locx=1172:b_locx=b_set_locx
            b_set_locy=365:b_locy=b_set_locy
            b_set_height=10:b_height=b_set_height
            b_set_width=10:b_width=b_set_width
		    b_colr=colorbandnew[0,255]
		    b_colg=colorbandnew[1,255]
		    b_colb=colorbandnew[2,255] 
            gosub drawcolbutton
            refresh
         end if
         clickclear
      end while
   end if
   # is the mouse on the OK button.
   if mousex > 980 and mousex < 1040 then
      while mouseb = 1
         if mousey > 320 and mousey < 340 then
            clickclear
            b_pressed=1
            b_update_locx=980:b_locx=b_update_locx
            b_update_locy=320:b_locy=b_update_locy
            b_update_height=20:b_height=b_update_height
            b_update_width=60:b_width=b_update_width
            gosub drawbutton
            refresh
            pause 0.2
            b_pressed=0
            b_text$="OK"
            gosub drawbutton
            sw_custseg=0
            # draw white to black
            for i2 = 0 to 255
               colorband[3+UserCol,i2]=rgb(colorbandnew[0,i2], colorbandnew[1,i2],colorbandnew[2,i2])
            next i2
         end if
         #reset to normal color screen
         sw_sel$="Colors"
         gosub Screen_Colour
         # reset bar
         for i = 0 to 255 step 1
    		colorbandnew[0,i] = 256-i     # red component reset
    		colorbandnew[1,i] = 256-i     # green component reset
    		colorbandnew[2,i] = 256-i     # blue component reset            			colorbandcustom[0,i]=-1
            colorbandcustom[1,i]=0
            colorbandcustom[2,i]=0
         next i
      end while
   end if
   # is the mouse on the Cancel button.
   if mousex > 1060 and mousex < 1120 then
      while mouseb = 1
         if mousey > 320 and mousey < 340 then
            clickclear
            b_pressed=1
            b_cancel_locx=1060:b_locx=b_cancel_locx
            b_cancel_locy=320:b_locy=b_cancel_locy
            b_cancel_height=20:b_height=b_cancel_height
            b_cancel_width=60:b_width=b_cancel_width
            gosub drawbutton
            refresh
            pause 0.2
            b_pressed=0
            gosub drawbutton
            # reset bar
            for i = 0 to 255 step 1
    			colorbandnew[0,i] = 256-i     # red component reset
    			colorbandnew[1,i] = 256-i     # green component reset
    			colorbandnew[2,i] = 256-i     # blue component reset
               	colorbandcustom[0,i]=-1
               	colorbandcustom[1,i]=0
               	colorbandcustom[2,i]=0
            next i
            #reset to normal color screen
            sw_sel$="Colors"
            gosub Screen_Colour
         end if
      end while
   end if
end if
goto loop
#**********************************
# Screen Painting: Mandel Option
#**********************************
Screen_Mandel:
color grey
spritehide 0
spritehide 1
spritehide 2
spritehide 3
rect 608,40,592,560
refresh
tab_active=1
gosub drawtabs
dim radio1$(4)
radio1$={"Escape Time. Based on number of iterations. (8 color bands)","Escape Time. Smooth, needs another color set selected from the 'Colors' tab)","Exit Quadrant (pretty dumb coloring scheme as I was out of ideas)"}
radio_elements=3
radio_locx=650:radio_locy_top=110:radio_locy_bot=400
radio_active=mand_radio_active
gosub drawradio
# Show Calculate button
b_text$= "Calculate":b_textsize=10
b_offsetx=12:b_offsety=3
b_pressed=0
b_update_locx=680:b_locx=b_update_locx
b_update_locy=550:b_locy=b_update_locy
b_update_height=25:b_height=b_update_height
b_update_width=80:b_width=b_update_width
gosub drawbutton
# Show Reset button
b_text$= "Reset":b_textsize=10
b_offsetx=20:b_offsety=3
b_pressed=0
b_reset_locx=780:b_locx=b_reset_locx
b_reset_locy=550:b_locy=b_reset_locy
b_reset_height=25:b_height=b_reset_height
b_reset_width=80:b_width=b_reset_width
gosub drawbutton
refresh
return
#**********************************
# Screen Painting: Julia Option
#**********************************
Screen_Julia:
spritehide 0
spritehide 1
spritehide 2
spritehide 3
color grey
rem rect 304,40,294,258
rect 608,40,592,558
refresh
tab_active=2
gosub drawtabs
refresh
draw_locx = 680:draw_locy = 120
draw_width = 430:draw_height = 430
draw_offsetx = 0: draw_offsety=0
draw_insetx = 0.01: draw_insety=0.01
draw_elements_x=1:draw_elements_y=1
draw_color=2
gosub drawing
color black
text 700,560,"x = "
text 900,560,"yi = "
draw_locx = 750:draw_locy = 560
draw_width = 100:draw_height = 15
draw_offsetx = 100: draw_offsety=0
draw_insetx = 0.01: draw_insety=0.01
draw_elements_x=2:draw_elements_y=1
draw_color=1
gosub drawing
color black
font "Tahoma",12,10
text 640,55,"Move the mouse over the Mandelbrot set to see a preview "
text 640,72,"of the Julia set of that particular complex coordinate." 
text 640,89,"Click to render in full. Click again to contnue"
color black
refresh
return
#**********************************
# Screen Painting: Zoom Option
#**********************************
Screen_Zoom:
spritehide 0
spritehide 1
spritehide 2
spritehide 3
color grey
rect 608,40,592,558
color black
font "Tahoma",12,100
text 640,60,"Select area to zoom"
draw_locx = 670:draw_locy = 100
draw_width = 285:draw_height = 285
draw_offsetx = 0: draw_offsety=0
draw_insetx = 0.01: draw_insety=0.01
draw_elements_x=1:draw_elements_y=1
draw_color=1
gosub drawing
refresh
for i = 10 to 580 step 2
   for j = 10 to 578 step 2
      colr=pixel(i,j)
      color colr
      plot 665+i/2,95+j/2
   next j
next i
refresh
color black
font "Tahoma",12,100
text 950,60,"Iterations"
font "Tahoma",10,100
text 1030,90,"- 30"
text 1030,140,"-80"
text 1030,190,"-130"
text 1030,240,"-185"
text 1030,290,"-240"
text 1030,340,"-290"
text 1030,390,"-340"
slider_locx_top=1000:slider_locy_top=90:slider_locx_bot=1000:slider_locy_bot=400
slider_orient=0
gosub drawslider
refresh
# Show Update button
b_text$= "Update":b_textsize=12
b_offsetx=20:b_offsety=3
b_pressed=0
b_update_locx=700:b_locx=b_update_locx
b_update_locy=450:b_locy=b_update_locy
