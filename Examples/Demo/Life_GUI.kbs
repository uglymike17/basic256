#**********************************
# sub routine "insert"
#**********************************
insert:
i=insert_offsetx
j=insert_offsety
k=0
while exstring[k] <>999
  rw=i+exstring[k]
  kl=j+exstring[k+1] 
  area[rw,kl]=1
  areacol[rw,kl]=1
  k=k+2
endwhile
return
#**********************************
# sub routine "AboutInfo"
#**********************************
AboutInfo:
sw_controls=0
canvas_x=471
canvas_y=561
graphsize canvas_x,canvas_y
color grey
rect 0,0,canvas_x,canvas_y
dim draw(10,10) fill 0
draw_elements_x=1
draw_elements_y=1
draw_locx=10:draw_locy=90
draw_width=size_x:draw_height=390
draw_offsetx=0:draw_offsety= 0
draw_insetx=0.005:draw_insety=0.005  
draw_color = 2
draw_text=0
gosub drawing
color black
font "Tahoma",14,100
text 100,40,"'Life'-type Cellular Automata"
font "Tahoma",10,100
text 20,105,"The Game of Life is a cellular automaton devised by the British "
text 20,119,"mathematician John Horton Conway in 1970 and it appeared in " 
text 20,133,"Scientific American's 'Mathematical Games' column in October '70"
text 20,147,"  "
text 20,163,"It is is a zero-player simulation game, meaning that its evolution is "
text 20,177,"determined by its initial state. Life is 'played' by creating an initial "
text 20,191,"configuration and observing how it evolves. This program DOES"
text 20,205,"allow you to paint on the canvas while the simulation is running."
text 20,233,"The cellular automata of the 'Life' family shown here are limited"
text 20,247,"to examining the current state of a cell's direct neighbours. Even"
text 20,262,"within this set of constraints, Conway's Game of life is just one of"
text 20,276,"many variants possible, some of which are included here as well."
text 20,304,"Wikipedia link: "
text 20,318,"         https://en.wikipedia.org/wiki/Life-like_cellular_automaton"
text 20,346,"Best Online Cellular Automaton:  "
text 20,364,"        https://mcell.ca/app/ and https://conwaylife.com/"
text 20,400,"This program was written in Basic-256, a simple yet useable Basic"  
text 20,415,"interpreter. It uses a primitive GUI toolkit called BTK2 which I"
text 20,430,"wrote, together with a set of other small demo programs"
#control buttons
b_start_locx=35:b_start_locy=520
b_locx=b_start_locx:b_locy=b_start_locy
b_width=65:b_height=20
b_text$="Start":b_textsize=10
b_offsetx=15:b_offsety= 2
b_pressed=0
gosub button
b_control_locx=125:b_control_locy=520
b_locx=b_control_locx:b_locy=b_control_locy
b_width=65:b_height=20
b_text$="Controls":b_textsize=10
b_offsetx=5:b_offsety= 2
b_pressed=0
gosub button
refresh
loopabout:
if mousey > b_start_locy and mousey<b_start_locy+b_height then
  if mousex>b_start_locx and mousex<b_start_locx+b_width then
    if clickb=1 then
      b_locx=b_start_locx:b_locy=b_start_locy
      b_width=65:b_height=20
      b_text$="Start":b_textsize=10
      b_offsetx=15:b_offsety= 2
      b_pressed=1
      gosub button
      pause 0.2
      b_locx=b_start_locx:b_locy=b_start_locy
      b_width=65:b_height=20
      b_text$="Start":b_textsize=10
      b_offsetx=15:b_offsety= 2
      b_pressed=0
      gosub button
      clickclear
      sw_realstart=1
      sw_controls = 0
    endif
  else
    if mousex>b_control_locx and mousex<b_control_locx+b_width then
      if clickb=1 then
        b_locx=b_control_locx:b_locy=b_control_locy
        b_width=65:b_height=20
        b_text$="Control":b_textsize=10
        b_offsetx=5:b_offsety= 2
        b_pressed=1
        gosub button
        pause 0.2
        b_locx=b_control_locx:b_locy=b_control_locy
        b_width=65:b_height=20  
        b_text$="Control":b_textsize=10
        b_offsetx=5:b_offsety= 2
        b_pressed=0
        gosub button
        clickclear
      sw_realstart=1
      sw_controls = 1        
      endif
    endif
  endif
endif
if sw_realstart=1 then return
goto loopabout
return
#**********************************
# sub routine "LifeControls"
#**********************************
LifeControls:
sw_realstart=0
sw_About=0
color red
line 5,5, 190,5
line 190,5, 190,95
line 190,95, 5,95
line 5,95, 5,5
font "Tahoma",10,100
text 10,100,"Initialization"
color black
font "Tahoma",8,100
text 10,118,"Click the 'Freehand'-button to draw on the canvas. "
text 10,131,"       Left-mouse:turn-on, right-mouse:turn-off"
text 10,147,"Click the 'Random'-button to 'populate' the canvas in a random fashion. "
text 10,160,"       The spinner-button determines the chance a cell has of becoming live"
text 10,176,"Click the 'Load'-button to draw a limited number of predefined forms "
text 10,189,"       This is only for Conway and the spinner contains the name of the 'creature'"
color green
line 195,5, 330,5
line 330,5, 330,95
line 330,95, 195,95
line 195,95, 195,5
font "Tahoma",10,100
text 10,205,"Variant and feedback"
color black
font "Tahoma",8,100
text 10,223,"Use the spinner to select the life 'variant' you want. Life is ruled by different"
text 10,236,"'Rulesets' For Conway, a cell survives (the 's') with 2 or 3 neighbours, while"
text 10,249,"cells are born (the 'b') with exactly 3 neighbours. In other cases the cell is dead"
text 10,265,"Some variants are better with populated fields, others are better with a seed"
text 10,281,"Gnarl, Serviettes and Replicator are the second kind. For Replicater, try a very "
text 10,294,"small drawing in the center. It will be repeated after every 8 iterations"
color blue
line 332,5, 403,5
line 403,5, 403,95
line 403,95, 332,95
line 332,95,332,5
font "Tahoma",10,100
text 10,310,"Action buttons"
color black
font "Tahoma",8,100
text 10,328,"'Go' will simply start the simulation. All buttons except the Acion buttons will be "
text 10,342,"    disabled. To indicate this, the indicator light will be turned red"
text 10,355,"'Step' allows you to halt after every iteration, allowing you to see the dynamics"
text 10,368,"    While Steps is active, the indicator light will be turned orange"
text 10,381,"'Stop' will stop the simulation (not the program). The indicator light will turn"
text 10,394,"    green, indicating that all buttons are clickable"
color yellow
line 406,5, 466,5
line 466,5, 466,95
line 466,95, 406,95
line 406,95, 406,5
font "Tahoma",10,100
text 10,405,"Appearance"
color black
font "Tahoma",8,100
text 10,423,"Color will turn newly born cells yellow, surviving cells red and dead cells green"
text 10,436,"Grid will draw the cells in a 3D-ish grid. When disabled, the simulation goes a lot"
text 10,449,"faster but looks a bit 'pixilated'"
text 10,462,"Clear clears ALL cells. The result is immediate so can also be used as a clear button"
text 10,475,"Zoom will make the cells bigger but the environment smaller. The environment"
text 10,488,"is in fact a torus where sides are connected as are top and bottom"
#control buttons
b_start_locx=35:b_start_locy=520
b_locx=b_start_locx:b_locy=b_start_locy
b_width=65:b_height=20
b_text$="Start":b_textsize=10
b_offsetx=15:b_offsety= 2
b_pressed=0
gosub button
b_about_locx=125:b_about_locy=520
b_locx=b_about_locx:b_locy=b_about_locy
b_width=65:b_height=20
b_text$="About":b_textsize=10
b_offsetx=12:b_offsety= 2
b_pressed=0
gosub button
refresh
loopcontrol:
if mousey > b_start_locy and mousey<b_start_locy+b_height then
  if mousex>b_start_locx and mousex<b_start_locx+b_width then
    if clickb=1 then
      b_locx=b_start_locx:b_locy=b_start_locy
      b_width=65:b_height=20
      b_text$="Start":b_textsize=10
      b_offsetx=15:b_offsety= 2
      b_pressed=1
      gosub button
      pause 0.2
      b_locx=b_start_locx:b_locy=b_start_locy
      b_width=65:b_height=20
      b_text$="Start":b_textsize=10
      b_offsetx=15:b_offsety= 2
      b_pressed=0
      gosub button
      clickclear
      sw_realstart=1
      sw_controls = 0
    endif
  else
    if mousex>b_about_locx and mousex<b_about_locx+b_width then
      if clickb=1 then
        b_locx=b_about_locx:b_locy=b_about_locy
        b_width=65:b_height=20
        b_text$="About":b_textsize=10
        b_offsetx=12:b_offsety= 2
        b_pressed=1
        gosub button
        pause 0.2
        b_locx=b_about_locx:b_locy=b_about_locy
        b_width=65:b_height=20  
        b_text$="About":b_textsize=10
        b_offsetx=12:b_offsety= 2
        b_pressed=0
        gosub button
        clickclear
        sw_About=1
      endif
    endif
  endif
endif
if sw_About=1 then gosub AboutInfo
if sw_realstart=1 then return
goto loopcontrol
return
