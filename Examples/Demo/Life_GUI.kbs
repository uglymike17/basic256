   sp_percent_inc=5

   spin_locx=sp_percent_locx:spin_locy=sp_percent_locy
   spin_width=sp_percent_width:spin_heigth=sp_percent_heigth
   spin_array=sp_percent_array
   spin_min=sp_percent_min
   spin_max=sp_percent_max
   spin_inc=sp_percent_inc
   spin_init=sp_percent_init
   gosub spinner 
   sp_percent_up_x=spin_up_topleft_x 
   sp_percent_up_y=spin_up_topleft_y 
   sp_percent_down_x=spin_up_botright_x 
   sp_percent_down_y=spin_up_botright_y 
   sp_percent_updown_width=spin_heigth
   sp_percent_updown_heigth=spin_heigth/2     
return
#******************************************
# sub routine "initialize loader spinner"
#******************************************
loaderspinner:
     sp_load_locx=75:sp_load_locy=65
     sp_load_width=80:sp_load_heigth=20
     spin_offsetx=0:spin_offsety= 0
     spin_insetx=0.05:spin_insety=0.1
     sp_load_array=1
     spin_color = 1

     sp_load_array_max=5
     dim sp_array_list$(6)
     for i = 0 to 5
       sp_array_list$[i]=sp_load_list$[i]
     next i
     spin_locx=sp_load_locx:spin_locy=sp_load_locy
     spin_width=sp_load_width:spin_heigth=sp_load_heigth
     spin_array=sp_load_array
     spin_array_active=sp_load_array_active
     spin_array_max=sp_load_array_max
     gosub spinner
     sp_load_up_x=spin_up_topleft_x 
     sp_load_up_y=spin_up_topleft_y 
     sp_load_down_x=spin_up_botright_x 
     sp_load_down_y=spin_up_botright_y 
     sp_load_updown_width=spin_heigth
     sp_load_updown_heigth=spin_heigth/2
return
#******************************************
# sub routine "State of cell based on rule"
#******************************************
liferule:
sw_found=0
area2[i,j]=0
area2col[i,j]=0
if area[i,j]=1 then
 if posb >2 then
   for val=2 to posb-1
     if string(counter) = mid(variant$,val,1) then 
       area2[i,j]=1
       area2col[i,j]=2
       sw_found=1
     else
       if sw_found=0 and areacol[i,j]=2 then area2col[i,j]=3
     endif
   next val
 else
    area2[i,j]=3  
    area2col[i,j]=3
 endif  
else
   for val=posb+1 to length(variant$)
     if string(counter) = mid(variant$,val,1) then 
       area2[i,j]=1
       area2col[i,j]=1
       sw_found=1
     else
       if sw_found=0 then area2col[i,j]=0
     endif
   next val
endif
if sw_found=1 then
      areacheck2[i,j]=1
      areacheck2[i-1,j]=1
      areacheck2[i+1,j]=1
      areacheck2[i,j-1]=1
      areacheck2[i,j+1]=1
      areacheck2[i-1,j-1]=1
      areacheck2[i-1,j+1]=1
      areacheck2[i+1,j-1]=1
      areacheck2[i+1,j+1]=1
endif
return
