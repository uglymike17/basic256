#**********************************
# sub routine "Draw a checkbox"
#**********************************
checkbox:
color white
rect check_locx,check_locy,12,12
color darkgrey
line check_locx,check_locy,check_locx+11, check_locy
line check_locx,check_locy,check_locx,check_locy+11 
color black
line check_locx+1,check_locy+1,check_locx+10, check_locy+1
line check_locx+1,check_locy+1,check_locx+1, check_locy+10
color grey
line check_locx+1,check_locy+11,check_locx+11, check_locy+11
line check_locx+11, check_locy+1,check_locx+11, check_locy+11
color black
font "Tahoma",10,100
text check_locx+20, check_locy - 3,check_label$
if check_change=1 then 
  if check_mark=1 then 
    check_mark=0
  else
    check_mark=1 
  endif
endif
if check_mark=1 then
  color black
  line check_locx+3, check_locy+6, check_locx+6, check_locy+9
  line check_locx+3, check_locy+5, check_locx+6, check_locy+8
  line check_locx+3, check_locy+4, check_locx+6, check_locy+8
  line check_locx+6, check_locy+9,check_locx+12,check_locy
  line check_locx+6, check_locy+8,check_locx+12,check_locy
  line check_locx+6, check_locy+7,check_locx+12,check_locy
else
  color white
  rect check_locx+2,check_locy+2,6,6
endif
check_change=0
refresh
return
#**********************************
# sub routine "Draw a grouping area"
#**********************************
grouper:
backgr=pixel(g_locx+g_width/2,g_locy+g_height/2)
color darkgrey
line g_locx,g_locy,g_locx+g_width,g_locy
line g_locx+g_width,g_locy,g_locx+g_width,g_locy+g_height
line g_locx+g_width,g_locy+g_height,g_locx,g_locy+g_height
line g_locx,g_locy+g_height,g_locx,g_locy
color rgb(200,200,200)
line g_locx+1,g_locy+1,g_locx+g_width-1, g_locy+1
line g_locx+g_width+1, g_locy,g_locx+g_width+1,g_locy+g_height+1
line g_locx+g_width+1,g_locy+g_height+1,g_locx,g_locy+g_height+1
line g_locx+1,g_locy+1,g_locx+1,g_locy+g_height-1
color backgr
rect g_locx+10,g_locy-10,g_width/5*2,20
color black
font "Tahoma",10,100
text g_locx+g_width/7,g_locy-7,g_label$
refresh
return
#******************************************
# sub routine "Draw a drawing element grid"
#******************************************
drawing:
for i=1 to draw_elements_x
for j =1 to draw_elements_y
widthfiller=draw_width+draw_offsetx
heightfiller= draw_height+draw_offsety
color darkgrey
poly {draw_locx+((i-1)*widthfiller)-(draw_width*draw_insetx), draw_locy+((j-1)*heightfiller)-(draw_height*draw_insety), draw_locx+((i-1)*widthfiller)-(draw_width*draw_insetx), draw_locy+((j-1)*heightfiller)+draw_height+(draw_height*draw_insety), draw_locx+((i-1)*widthfiller)+draw_height/2,draw_locy+((j-1)*heightfiller)+draw_height/2}
poly {draw_locx+((i-1)*widthfiller)-(draw_width*draw_insetx), draw_locy+((j-1)*heightfiller)-(draw_height*draw_insety), draw_locx+((i-1)*widthfiller)+draw_height/2, draw_locy+((j-1)*heightfiller)+draw_height/2, draw_locx+((i-1)*widthfiller)+draw_width-draw_height/2, draw_locy+((j-1)*heightfiller)+draw_height/2, draw_locx+((i-1)*widthfiller)+draw_width+(draw_height*draw_insetx), draw_locy+((j-1)*heightfiller)-(draw_height*draw_insety)}
color rgb(200,200,200)
poly {draw_locx+((i-1)*widthfiller)-(draw_width*draw_insetx), draw_locy+((j-1)*heightfiller)+draw_height+(draw_height*draw_insety), draw_locx+((i-1)*widthfiller)+draw_height/2, draw_locy+((j-1)*heightfiller)+draw_height/2, draw_locx+((i-1)*widthfiller)+draw_width-draw_height/2, draw_locy+((j-1)*heightfiller)+ draw_height/2, draw_locx+((i-1)*widthfiller)+draw_width+(draw_height*draw_insety), draw_locy+((j-1)*heightfiller)+draw_height+(draw_height*draw_insety)}
poly {draw_locx+((i-1)*widthfiller)+draw_width-draw_height/2, draw_locy+((j-1)*heightfiller)+draw_height/2, draw_locx+((i-1)*widthfiller)+draw_width+(draw_width*draw_insetx), draw_locy+((j-1)*heightfiller)+draw_height+(draw_height*draw_insety), draw_locx+((i-1)*widthfiller)+draw_width+(draw_width*draw_insetx), draw_locy+((j-1)*heightfiller)-(draw_height*draw_insety)}
if draw_color = 1 then
color black
else
if draw_color = 2 then
color white
else
color grey
endif
endif
rect draw_locx+ (i-1)*widthfiller+(draw_width*draw_insetx), draw_locy +(j-1)*heightfiller+(draw_height*draw_insety), draw_width-draw_width* 2*draw_insetx+2, draw_height-draw_height* 1.5*draw_insety
if draw_color > 1 then
if draw_text=1 then
color black
font "Tahoma",draw_textsize,100
text draw_locx+ (i-1)*widthfiller+(draw_offsetx+2), draw_locy +(j-1)*heightfiller+(draw_offsety),draw_content$[i-1,j-1]
endif
endif
next j
refresh
next i
refresh
return
#*********************************
# sub routine "Draw a button"
#*********************************
button:
if b_pressed=0 then
color rgb(200,200,200)
poly {b_locx, b_locy, b_locx+b_width, b_locy, b_locx, b_locy+b_height}
color darkgrey
poly {b_locx+b_width, b_locy, b_locx+b_width, b_locy+b_height, b_locx, b_locy+b_height}
color grey
rect b_locx+b_width*0.05,b_locy+b_height*0.07, b_width-b_width*0.1, b_height-b_height*0.1
color black
font "Tahoma",b_textsize,100
text b_locx+b_offsetx,b_locy+b_offsety,b_text$
refresh
else
color darkgrey
poly {b_locx, b_locy, b_locx+b_width, b_locy, b_locx, b_locy+b_height}
color rgb(200,200,200)
poly {b_locx+b_width, b_locy, b_locx+b_width, b_locy+b_height, b_locx, b_locy+b_height}
color grey
rect b_locx+b_width*0.05,b_locy+b_height*0.07, b_width-b_width*0.1, b_height-b_height*0.1
color black
font "Tahoma",b_textsize,100
text b_locx+(b_offsetx+2),b_locy+(b_offsety+2),b_text$
end if
refresh
return
#***************************************
# sub routine "Draw a radio button list"
#***************************************
drawradio:
color black
font "Tahoma",10,100
radio_spacing = (radio_locy_bot-radio_locy_top)/(radio_elements-1)
for i = 0 to (radio_elements -1)
  color black
  circle radio_locx, radio_locy_top+(radio_spacing*i), 5
  color white
  circle radio_locx+1, radio_locy_top+(radio_spacing*i)+1,4
next i
#radio text captions
color black
for i = 0 to radio_elements-1
 text radio_locx + 15,radio_locy_top + (radio_spacing*i)-8, radio1$[i]
next i
# paint active radio button
circle radio_locx+1, radio_locy_top+(radio_spacing*(radio_active-1))+1,2
refresh
return
#******************************************
# sub routine "Draw a spin entry button"
#******************************************
spinner:
 widthfiller=spin_offsetx
 heigthfiller= spin_offsety
  color darkgrey
  poly {spin_locx, spin_locy, spin_locx, spin_locy+spin_heigth, spin_locx+spin_heigth/2, spin_locy+spin_heigth/2}
  poly {spin_locx, spin_locy, spin_locx+spin_heigth/2, spin_locy+spin_heigth/2, spin_locx+spin_width-spin_heigth/2, spin_locy+spin_heigth/2, spin_locx+spin_width, spin_locy}

  color rgb(200,200,200)
  poly {spin_locx, spin_locy+spin_heigth, spin_locx+spin_heigth/2, spin_locy+spin_heigth/2, spin_locx+spin_width-spin_heigth/2, spin_locy+spin_heigth/2, spin_locx+spin_width, spin_locy+spin_heigth}
  poly {spin_locx+spin_width-spin_heigth/2, spin_locy+spin_heigth/2, spin_locx+spin_width, spin_locy+spin_heigth, spin_locx+spin_width, spin_locy}
  if spin_color = 1 then
   color white
  else 
   color black
  endif
 rect spin_locx+(spin_width*spin_insetx), spin_locy+(spin_heigth*spin_insety), spin_width-spin_width*2*spin_insetx+2, spin_heigth-spin_heigth* 1.5*spin_insety

color rgb(200,200,200)
#Spin-up mini button
  spin_up_topleft_x = spin_locx+widthfiller+spin_width+spin_width/15
  spin_up_topleft_y = spin_locy+heigthfiller-2
  rect spin_up_topleft_x, spin_up_topleft_y ,spin_heigth ,spin_heigth/2
#Spin-down mini button
  spin_up_botright_x = spin_locx+widthfiller+spin_width+spin_width/15
  spin_up_botright_y = spin_locy+heigthfiller+spin_heigth/2
  rect spin_up_botright_x, spin_up_botright_y, spin_heigth ,spin_heigth/2
color darkgrey
# upper mini button lower shadow line
  line spin_locx+widthfiller+spin_width+spin_width/15,spin_locy+heigthfiller-2+spin_heigth/2,spin_locx+widthfiller+spin_width+spin_width/15+spin_heigth,spin_locy+heigthfiller-2+spin_heigth/2
  line spin_locx+widthfiller+spin_width+spin_width/15,spin_locy+heigthfiller-3+spin_heigth/2,spin_locx+widthfiller+spin_width+spin_width/15+spin_heigth,spin_locy+heigthfiller-3+spin_heigth/2

# lower mini button lower lower shadow line
line spin_locx+widthfiller+spin_width+spin_width/15,spin_locy+heigthfiller+spin_heigth/2+2+spin_heigth/2,spin_locx+widthfiller+spin_width+spin_width/15+spin_heigth,spin_locy+heigthfiller+spin_heigth/2+2+spin_heigth/2
line spin_locx+widthfiller+spin_width+spin_width/15,spin_locy+heigthfiller+spin_heigth/2+1+spin_heigth/2,spin_locx+widthfiller+spin_width+spin_width/15+spin_heigth,spin_locy+heigthfiller+spin_heigth/2+1+spin_heigth/2

# upper mini button right shadow line
  line spin_locx+widthfiller+spin_width+spin_heigth+spin_width/15,spin_locy+heigthfiller-2,spin_locx+widthfiller+spin_width+spin_heigth+spin_width/15,spin_locy+heigthfiller-2+spin_heigth/2
  line spin_locx+widthfiller+spin_width+spin_heigth+spin_width/15+1,spin_locy+heigthfiller-1,spin_locx+widthfiller+spin_width+spin_heigth+spin_width/15+1,spin_locy+heigthfiller-2+spin_heigth/2

#lower mini button right shadow line
  line spin_locx+widthfiller+spin_width+spin_heigth+spin_width/15,spin_locy+heigthfiller+spin_heigth/2+2,spin_locx+widthfiller+spin_width+spin_heigth+spin_width/15,spin_locy+heigthfiller+spin_heigth
  line spin_locx+widthfiller+spin_width+spin_heigth+spin_width/15+1,spin_locy+heigthfiller+spin_heigth/2+3,spin_locx+widthfiller+spin_width+spin_heigth+spin_width/15+1,spin_locy+heigthfiller+spin_heigth-1

#Up arrow
color rgb(100,100,100)
poly { spin_locx+widthfiller+spin_width+spin_width/15+spin_heigth/4, spin_locy+heigthfiller+(spin_heigth/8*3)-2, spin_locx+widthfiller+spin_width+spin_width/15+spin_heigth/4*3, spin_locy+heigthfiller+(spin_heigth/8*3)-2, spin_locx+widthfiller+spin_width+spin_width/15+spin_heigth/4*2, spin_locy+heigthfiller+(spin_heigth/8)-2}
#down Arrow
poly { spin_locx+widthfiller+spin_width+spin_width/15+spin_heigth/4, spin_locy+heigthfiller+spin_heigth/2+(spin_heigth/8), spin_locx+widthfiller+spin_width+spin_width/15+spin_heigth/4*3, spin_locy+heigthfiller+spin_heigth/2+(spin_heigth/8), spin_locx+widthfiller+spin_width+spin_width/15+spin_heigth/4*2, spin_locy+heigthfiller+spin_heigth/2+(spin_heigth/8*3)}

#initialize
if spin_array=0 then  
      color black
      font "Tahoma",spin_heigth/2,10
      text spin_locx+spin_width/5,spin_locy+3,spin_init
else
      color black
      font "Tahoma",spin_heigth/2,10
      text spin_locx+10,spin_locy+3,sp_array_list$[spin_array_active]
endif
refresh
return
