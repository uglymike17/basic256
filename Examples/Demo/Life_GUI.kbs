   spin_array_max=sp_variant_array_max
   gosub spinner
   sp_variant_up_x=spin_up_topleft_x 
   sp_variant_up_y=spin_up_topleft_y 
   sp_variant_down_x=spin_up_botright_x 
   sp_variant_down_y=spin_up_botright_y 
