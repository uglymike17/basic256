#Return button liquid
#*******************
liquid_b3:
dim rangeb2(300) fill 0
sw=1
k=0
seedy=rand
sizx=100
x1=250
y1=410
amplitude=48
frequency=10
oldx=0
offset=0
gosub perlin
sw=0
refresh
return

#create Perlin noise for liquid
#******************************
perlin:
gosub myRnd
pointb=a
for zz= 1 to frequency
   if zz=1 then
      pointa=0
   else
      pointa=pointb
   endif
   gosub myRnd
   if zz=frequency then
      pointb=0
   else
      pointb=a
   endif
   for x=0 to 1 step (1/(sizx/frequency))
      if sw=1 then
         ft = x * 3.1415927
         f = (1 - cos(ft)) * .5
         interp= pointa*(1-f) + pointb*f
      else
         interp= pointa*(1-x) + pointb*x
      endif
      color rgb(100,100,220)
      line (x*(sizx/frequency)+oldx)+x1,y1,(x*(sizx/frequency)+oldx+x1), y1+interp*amplitude+offset
      color blue
      line (x*(sizx/frequency)+oldx)+x1,y1,(x*(sizx/frequency)+oldx)+x1, y1+interp*amplitude+offset-5
      range[k]=range[k]+(interp*amplitude)
      k=k+1
   next x
   oldx=oldx+(sizx/frequency)
next zz
return

#Seeded Random Number Generator for Perlin
myRnd:
seedy=(221*seedy)+2113
seedy=seedy-(INT(seedy/10000)*10000)
a=seedy/10000
return

# Print the Game rules
#*********************
Howto:
draw_elements_x=1
draw_elements_y=1
draw_locx=130:draw_locy=220
draw_width=351:draw_height=150
draw_offsetx=20:draw_offsety= 20
draw_insetx=0.02:draw_insety=0.02
draw_color = 1
gosub drawing
color black
font "Tahoma",10,100
text draw_locx+draw_offsetx, draw_locy+draw_offsety, "Your initial position starts from the top left."
text draw_locx+draw_offsetx, draw_locy+draw_offsety+20, "Select one of the colors from the selector"
text draw_locx+draw_offsetx, draw_locy+draw_offsety+40, "to change your initial color and to add all "
text draw_locx+draw_offsetx, draw_locy+draw_offsety+60,"adjacent blocks of that color to the flooded "
text draw_locx+draw_offsetx, draw_locy+draw_offsety+80, "area. The aim is to flood the entire area in "
text draw_locx+draw_offsetx, draw_locy+draw_offsety+100, "smallest number of steps..."
gosub liquid_b3
b_locx=250:b_locy=380
b_locx_return=250:b_locy_return=380
b_width=100:b_height=30
b_text$="Return":b_textsize=12
b_offsetx=22:b_offsety= 6
b_pressed=0
gosub button
clickclear
while 1=1
   b_sw_pressed=0
   if clickb=1 then
      if mousey > b_locy_return and mousey < b_locy_return+b_height then
         if mousex > b_locx_return and mousex < b_locx_return + b_width then
            if b_pressed=0 then
               b_pressed=1
               b_sw_pressed=1
            end if
b_locx=250:b_locy=380
b_width=100:b_height=30
b_text$="Return":b_textsize=12
b_offsetx=22:b_offsety= 6
            gosub button
            refresh
            pause 0.1
            if b_sw_pressed=1 then
               b_sw_pressed=0
               b_pressed=0
               gosub button
            end if
            gosub paintsplash
            refresh
            return
         endif
      endif
   endif
end while

#*********************************
# sub routine "Draw a button"
#*********************************
button:
if b_pressed=0 then
   color rgb(200,200,200)
   poly {b_locx, b_locy, b_locx+b_width, b_locy, b_locx, b_locy+b_height}
   color darkgrey
   poly {b_locx+b_width, b_locy, b_locx+b_width, b_locy+b_height, b_locx, b_locy+b_height}
   color grey
   rect b_locx+b_width*0.05, b_locy+b_height*0.07, b_width-b_width*0.1, b_height-b_height*0.1
   color black
   font "Tahoma",b_textsize,100
   text b_locx+b_offsetx,b_locy+b_offsety,b_text$
   refresh
else
   color darkgrey
   poly {b_locx, b_locy, b_locx+b_width, b_locy, b_locx, b_locy+b_height}
   color rgb(200,200,200)
   poly {b_locx+b_width, b_locy, b_locx+b_width, b_locy+b_height, b_locx, b_locy+b_height}
   color grey
   rect b_locx+b_width*0.05 ,b_locy+b_height*0.07, b_width-b_width*0.1, b_height-b_height*0.1
   color black
   font "Tahoma",b_textsize,100
   text b_locx+(b_offsetx+2), b_locy+(b_offsety+2),b_text$
end if
refresh
return


#******************************************
# sub routine "Draw a drawing element grid"
#******************************************
drawing:
for i=1 to draw_elements_x
   for j =1 to draw_elements_y
      widthfiller=draw_width+draw_offsetx
      heightfiller= draw_height+draw_offsety
      color darkgrey
      poly {draw_locx+((i-1)*widthfiller), draw_locy+((j-1)*heightfiller), draw_locx+((i-1)*widthfiller), draw_locy+((j-1)*heightfiller)+draw_height, draw_locx+((i-1)*widthfiller)+draw_height/2, draw_locy+((j-1)*heightfiller)+draw_height/2}
      poly {draw_locx+((i-1)*widthfiller), draw_locy+((j-1)*heightfiller), draw_locx+((i-1)*widthfiller)+draw_height/2, draw_locy+((j-1)*heightfiller)+draw_height/2, draw_locx+((i-1)*widthfiller)+draw_width-draw_height/2, draw_locy+((j-1)*heightfiller)+draw_height/2, draw_locx+((i-1)*widthfiller)+draw_width,draw_locy+((j-1)*heightfiller)}
      color rgb(200,200,200)
      poly {draw_locx+((i-1)*widthfiller), draw_locy+((j-1)*heightfiller)+draw_height, draw_locx+((i-1)*widthfiller)+draw_height/2, draw_locy+((j-1)*heightfiller)+draw_height/2, draw_locx+((i-1)*widthfiller)+draw_width-draw_height/2, draw_locy+((j-1)*heightfiller)+draw_height/2, draw_locx+((i-1)*widthfiller)+draw_width, draw_locy+((j-1)*heightfiller)+draw_height}
      poly {draw_locx+((i-1)*widthfiller)+draw_width-draw_height/2, draw_locy+((j-1)*heightfiller)+draw_height/2, draw_locx+((i-1)*widthfiller)+draw_width, draw_locy+((j-1)*heightfiller)+draw_height, draw_locx+((i-1)*widthfiller)+draw_width,draw_locy+((j-1)*heightfiller)}
      if draw_color = 1 then
         color white
      else
         color black
      endif
      rect draw_locx+(i-1)*widthfiller+(draw_width*draw_insetx), draw_locy+(j-1)*heightfiller+(draw_height*draw_insety), draw_width-draw_width* 2*draw_insetx+2, draw_height-draw_height* 1.5*draw_insety
   next j
next i
refresh
return

#**********************************
# sub routine "Draw a grouping area"
#**********************************
grouper:
#get background color
backgr=pixel(g_locx+g_width-1,g_locy+g_height-1)
color darkgrey
line g_locx, g_locy, g_locx+g_width, g_locy
line g_locx+g_width, g_locy,g_locx+g_width, g_locy+g_height
line g_locx+g_width, g_locy+g_height,g_locx, g_locy+g_height
line g_locx, g_locy+g_height, g_locx,g_locy
color rgb(200,200,200)
line g_locx+1, g_locy+1, g_locx+g_width-1, g_locy+1
line g_locx+g_width+1, g_locy,g_locx+g_width+1, g_locy+g_height+1
line g_locx+g_width+1, g_locy+g_height+1,g_locx, g_locy+g_height+1
line g_locx+1, g_locy+1, g_locx+1, g_locy+g_height-1
color backgr
# if g_label$ has content, write it on the top left side of the grouper element
if length(g_label$)>0 then
   rect g_locx+10,g_locy-10,g_width/5*2,20
   color black
   font "Tahoma",10,100
   text g_locx+g_width/7,g_locy-7,g_label$
endif
refresh
return

function alpha(hexcol)
alpha = hexcol/256/256/256%256
end function

function rood(hexcol)
rood = hexcol/256/256%256
end function

function groen(hexcol)
groen = hexcol/256%256
end function

function blauw(hexco)
blauw = hexco%256
end function
