#Let's Play button liquid
#*******************
liquid_b2:
dim rangeb2(300) fill 0
sw=1
k=0
seedy=rand
sizx=120
x1=330
y1=280
amplitude=48
frequency=10
oldx=0
offset=0
gosub perlin
